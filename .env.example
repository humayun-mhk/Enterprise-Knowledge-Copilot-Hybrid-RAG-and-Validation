# Application
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
MAX_UPLOAD_MB=25

# Storage and retrieval
VECTOR_STORE=chroma
CHROMA_PERSIST_DIR=/app/storage/chroma
METADATA_DB_URL=sqlite:////app/storage/copilot.db
UPLOAD_DIR=/app/storage/uploads
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_ENABLED=true
CHUNK_SIZE=800
CHUNK_OVERLAP=120
DENSE_TOP_K=20
BM25_TOP_K=20
RERANK_TOP_K=10
RRF_K=60
MIN_EVIDENCE_SCORE=0.25

# LLM provider: extractive | openai | anthropic | google | ollama
LLM_PROVIDER=extractive
LLM_MODEL=deterministic-extractive-v1
LLM_TEMPERATURE=0
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b

# Observability and evaluation
MLFLOW_TRACKING_URI=http://mlflow:5000
EVALUATION_RESULTS_DIR=/app/evaluation-results
PROMPT_VERSION=answer-v1
VALIDATOR_PROMPT_VERSION=validator-v1
ENABLE_LLM_JUDGE=false
VITE_API_BASE_URL=/api
